#!/usr/bin/env bash
# First-time setup. Run after cloning the repo.
set -euo pipefail

REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO"

OC="$HOME/.config/opencode"
EXCLUDES=(--exclude node_modules --exclude package.json --exclude package-lock.json --exclude bun.lock --exclude dcp.jsonc)
ENGRAM_BIN="${ENGRAM_BIN:-engram}"

echo "== ai-orchestrator-setup bootstrap =="

# 1. Replace incompatible upstream Engram builds with the pinned CAS release.
if [ "$ENGRAM_BIN" = "engram" ]; then
  "$REPO/bin/install-engram"
else
  echo "-> Using ENGRAM_BIN override: $ENGRAM_BIN"
fi

# 2. Install codegraph (codebase knowledge graph for structural queries).
if ! command -v codegraph >/dev/null 2>&1; then
  echo "-> Installing codegraph..."
  npm install -g @colbymchenry/codegraph
else
  echo "-> codegraph already installed"
fi

# --- DCP (Dynamic Context Pruning) plugin -------------------------------
DCP_PKG="@tarquinen/opencode-dcp@3.1.14"
if npm ls -g "$DCP_PKG" >/dev/null 2>&1; then
  echo "DCP already installed ($DCP_PKG)."
else
  echo "Installing DCP ($DCP_PKG)..."
  npm install -g "$DCP_PKG" || echo "WARN: DCP global install failed; OpenCode will install it from the plugin array on start."
fi

# 3. Warn if opencode is missing.
if ! command -v opencode >/dev/null 2>&1; then
  echo "!! opencode not found. Install it with: brew install opencode"
fi

# 4. Stage config and verify the installed Engram capability contract before
#    touching the active config. Homebrew stable is not assumed to provide it.
STAGE="$(mktemp -d "${TMPDIR:-/tmp}/ai-orchestrator-bootstrap.XXXXXX")"
trap 'rm -rf "$STAGE"' EXIT
rsync -a --delete "${EXCLUDES[@]}" "$REPO/config/" "$STAGE/"

echo "-> Checking Engram atomic topic CAS capability..."
CAPABILITIES_JSON="$("$ENGRAM_BIN" capabilities --json 2>/dev/null)" || CAPABILITIES_JSON=""
if ! CAPABILITIES_JSON="$CAPABILITIES_JSON" python3 <<'PY'
import json
import os
import sys

try:
    capabilities = json.loads(os.environ["CAPABILITIES_JSON"])
    if capabilities.get("schema_version") != 1:
        raise RuntimeError("schema_version must be 1")
    feature = capabilities["features"]["atomic_topic_cas"]
    if feature.get("supported") is not True:
        raise RuntimeError("features.atomic_topic_cas.supported must be true")
    expected_revision = feature["input"]["expected_revision"]
    expected_input = {"type": "integer", "minimum": 0, "requires": "topic_key"}
    if expected_revision != expected_input:
        raise RuntimeError(f"expected_revision must declare exactly {expected_input}")
    contracts = {
        "success_fields": {"id", "sync_id", "revision_count"},
        "error_codes": {
            "revision_conflict",
            "expected_revision_requires_topic",
            "invalid_expected_revision",
        },
    }
    for field, expected in contracts.items():
        declared = feature.get(field)
        if not isinstance(declared, list) or len(declared) != len(expected) or set(declared) != expected:
            raise RuntimeError(f"features.atomic_topic_cas.{field} must declare exactly {sorted(expected)}")
except Exception as error:
    print(f"Engram capability preflight failed: {error}", file=sys.stderr)
    sys.exit(1)
PY
then
  echo "ERROR: bootstrap requires the Engram atomic_topic_cas capability contract (schema version 1)." >&2
  echo "       The active OpenCode config was not changed; existing backups remain intact." >&2
  echo "       Install a capability-bearing Engram release, then rerun bootstrap." >&2
  exit 1
fi

# 5. Back up any existing config, then install the staged orchestrator config.
if [ -d "$OC" ]; then
  BACKUP_BASE="$HOME/.config/opencode.backup.$(date +%Y%m%d-%H%M%S)"
  BACKUP="$BACKUP_BASE"
  BACKUP_SUFFIX=0
  while ! mkdir "$BACKUP" 2>/dev/null; do
    if [ ! -e "$BACKUP" ]; then
      echo "ERROR: could not reserve backup path: $BACKUP" >&2
      exit 1
    fi
    BACKUP_SUFFIX=$((BACKUP_SUFFIX + 1))
    BACKUP="$BACKUP_BASE.$BACKUP_SUFFIX"
  done
  echo "-> Backing up existing config to $BACKUP..."
  rsync -a --exclude node_modules "$OC/" "$BACKUP/"
fi
mkdir -p "$OC"
echo "-> Installing orchestrator config..."
# AGENTS.md is spliced separately (below) so user-owned regions are never
# clobbered or --deleted by the wholesale config install.
rsync -a --delete "${EXCLUDES[@]}" --exclude AGENTS.md "$STAGE/" "$OC/"

# 6. Splice AGENTS.md: replace tool-owned managed blocks with the staged
#    version while preserving every user-owned region verbatim. Runs AFTER the
#    main install so the live file is the merge base. POSIX awk only (portable
#    across macOS/BSD and Linux).
STAGED_AGENTS="$STAGE/AGENTS.md"
LIVE_AGENTS="$OC/AGENTS.md"
if [ -f "$STAGED_AGENTS" ]; then
  if [ -f "$LIVE_AGENTS" ]; then
    echo "-> Splicing managed regions into existing AGENTS.md..."
    SPLICE_TMP="$(mktemp "$OC/.AGENTS.md.XXXXXX")"
    if awk '
      BEGIN {
        nblk = 3
        om[1] = "<!-- ai-orchestrator:engram-protocol -->"
        cm[1] = "<!-- /ai-orchestrator:engram-protocol -->"
        om[2] = "<!-- ai-orchestrator:codegraph-guidance -->"
        cm[2] = "<!-- /ai-orchestrator:codegraph-guidance -->"
        om[3] = "<!-- ai-orchestrator:evidence-first-delegation -->"
        cm[3] = "<!-- /ai-orchestrator:evidence-first-delegation -->"
        scap = 0
        lskip = 0
      }
      # Pass 1: the staged file. Capture each managed block, line by line.
      FNR == NR {
        if (scap > 0) {
          scount[scap]++
          sline[scap, scount[scap]] = $0
          if ($0 == cm[scap]) scap = 0
          next
        }
        for (i = 1; i <= nblk; i++) {
          if ($0 == om[i]) {
            scap = i; shas[i] = 1
            scount[i] = 1; sline[i, 1] = $0
            next
          }
        }
        next
      }
      # Pass 2: the live file (the merge base).
      {
        if (lskip > 0) {
          if ($0 == cm[lskip]) lskip = 0
          next
        }
        matched = 0
        for (i = 1; i <= nblk; i++) {
          if ($0 == om[i]) matched = i
        }
        if (matched > 0) {
          lhas[matched] = 1
          if (shas[matched]) {
            for (k = 1; k <= scount[matched]; k++) print sline[matched, k]
            lskip = matched
          } else {
            # Managed marker in live but absent from staged: keep live verbatim.
            print $0
          }
          next
        }
        print $0
      }
      # Managed blocks present in staged but absent from live: append at EOF,
      # each preceded by one blank line, in staged order.
      END {
        for (i = 1; i <= nblk; i++) {
          if (shas[i] && !lhas[i]) {
            print ""
            for (k = 1; k <= scount[i]; k++) print sline[i, k]
          }
        }
      }
    ' "$STAGED_AGENTS" "$LIVE_AGENTS" > "$SPLICE_TMP"; then
      mv "$SPLICE_TMP" "$LIVE_AGENTS"
    else
      rm -f "$SPLICE_TMP"
      echo "ERROR: failed to splice AGENTS.md; left existing file untouched." >&2
      exit 1
    fi
  else
    echo "-> Installing AGENTS.md (no existing file)..."
    cp "$STAGED_AGENTS" "$LIVE_AGENTS"
  fi
fi

# --- DCP config: install default only if absent (preserve user edits) ---
if [ -f "$OC/dcp.jsonc" ]; then
  echo "Existing dcp.jsonc preserved."
else
  cp "$REPO/config/dcp.jsonc" "$OC/dcp.jsonc" && echo "Installed default dcp.jsonc."
fi

# --- DCP + Engram + agents validation -----------------------------------
echo "Validating DCP integration..."
dcp_fail=0
grep -q '@tarquinen/opencode-dcp' "$OC/opencode.json" || { echo "FAIL: DCP not in plugin array"; dcp_fail=1; }
npm ls -g @tarquinen/opencode-dcp >/dev/null 2>&1 && echo "OK: DCP installed" || echo "WARN: DCP not in global npm (OpenCode may load it from the array)"
python3 -c "import json,sys,re;s=''.join(l for l in open(sys.argv[1]) if not re.match(r'\s*//',l));json.loads(s)" "$OC/dcp.jsonc" && echo "OK: dcp.jsonc valid" || { echo "FAIL: dcp.jsonc invalid"; dcp_fail=1; }
grep -q '"engram"' "$OC/opencode.json" && [ -f "$OC/plugins/engram.ts" ] && echo "OK: Engram configured" || { echo "FAIL: Engram missing"; dcp_fail=1; }
grep -q '"ai-orchestrator"' "$OC/opencode.json" && echo "OK: agents configured" || { echo "FAIL: agents missing"; dcp_fail=1; }
[ "$dcp_fail" = 0 ] && echo "DCP validation passed." || { echo "DCP validation FAILED."; exit 1; }

echo
echo "OK bootstrap complete."
echo "   Restart OpenCode so it reloads the installed config and plugin."
echo "   Then open opencode and log into your model provider once"
echo "   (credentials are stored outside the config folder — never synced)."
echo
echo "   Optional: customize your persona in ~/.config/opencode/AGENTS.md"
echo "   The persona section at the top is yours to edit. The protocols below it"
echo "   (Engram, CodeGraph, Evidence-First Delegation, Skill Loading) are the"
echo "   orchestrator infrastructure."
echo
echo "   Optional experimental token reduction (verified with OpenCode 1.17.15):"
echo "   OPENCODE_EXPERIMENTAL_CODE_MODE=1 opencode"
